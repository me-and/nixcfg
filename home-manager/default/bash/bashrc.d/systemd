[[ -v TMUX_TASKLOOP ]] && return 0

__have_prompt=
for __cmd in "${PROMPT_COMMAND[@]}"; do
	if [[ "$__cmd" = _prompt_systemd ]]; then
		__have_prompt=Yes
		break
	fi
done
if [[ -z "$__have_prompt" ]]; then
	_prompt_systemd () {
		systemctl list-units --failed --quiet --no-pager
		systemctl --user list-units --failed --quiet --no-pager
	}

	# Not a great place to put this, but good enough for now: add a
	# newline before all the other commands I run that print output that
	# should be immediately before the prompt.
	if [[ -v PROMPT_COMMAND[50] ]]; then
		echo 'unexpected value already stored in Bash'\''s PROMPT_COMMAND[50]' >&2
	else
		PROMPT_COMMAND[50]=echo
	fi

	PROMPT_COMMAND+=(_prompt_systemd)
fi

